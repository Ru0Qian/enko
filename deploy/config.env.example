# Enko Web Console — 生产环境配置示例
# 用法：复制为 config.env 并填入真实值，或直接运行 setup.sh 自动生成 /etc/enko/config.env
#   cp config.env.example config.env
# 注意：真实的 config.env 不要提交到版本库（已在 .gitignore 中忽略）。

# ---- 项目路径 ----
ENKO_REPO_ROOT=/opt/enko
ENKO_WEB_ROOT=/opt/enko/web-console

# ---- 服务绑定 ----
ENKO_HOST=127.0.0.1
ENKO_PORT=8036
ENKO_WORKERS=2

# ---- JWT 密钥（setup.sh 会自动生成；手动部署时替换为 64 位随机 hex）----
ENKO_JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING
ENKO_JWT_EXPIRE_HOURS=24

# ---- 默认管理员账号（首次部署时由 setup.sh 生成随机密码；手动部署务必修改）----
ENKO_ADMIN_USER=admin
ENKO_ADMIN_PASS=CHANGE_ME_TO_A_STRONG_PASSWORD

# ---- Android 工具链（setup.sh 会自动填充）----
ANDROID_SDK_ROOT=/opt/android-sdk
ANDROID_NDK_HOME=/opt/android-sdk/ndk/27.0.12077973

# ---- 监听模式 ----
# HTTP 直连，Nginx 反代到 uvicorn
ENKO_LISTEN_PORT=80

# --- Database ---
# 部署时替换为强口令，不要使用 enko:enko 默认值
ENKO_DATABASE_URL=postgresql://enko:CHANGE_ME_DB_PASSWORD@localhost:5432/enko

# --- Security ---
# ENKO_CORS_ORIGINS=https://your-domain.com
ENKO_PRODUCTION=true
ENKO_MAX_CONCURRENT_JOBS=3

# --- Cleanup ---
ENKO_UPLOAD_TTL_HOURS=24
ENKO_JOB_TTL_DAYS=7
